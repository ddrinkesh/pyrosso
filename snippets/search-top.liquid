<div class="search-result-top">
  <div class="search-result-top-content">
    <div class="search-result-top-left">
      <div class="search-result-top__title">{{ section.settings.suggestions_title }}</div>
      <ul class="search-result-top__list collection-list">
        {%- for link in section.settings.suggestions_menu.links -%}
          <li class="search-result-top__item {% if link.links.size > 0 %}search-result-top__item--row {% endif %} collection-list__item">
            <a class="headline__title" href="{{ link.url }}"> {{ link.title }}</a>
            {% comment %}
              {% if link.links.size > 0 %}
                <a class="headline__title" href="{{ link.url }}"> {{ link.title }}</a>
                <div class="search-result-top__item__sublinks">
                  {% for sublink in link.links %}
                    <div class="search-result-top__item__sublink">
                      {% if sublink.type == 'product_link' or sublink.type == 'collection_link' %}
                        {% render 'card',
                          img: sublink.object.featured_image,
                          url: sublink.object.url,
                          title: sublink.object.title,
                          title_tag: 'div',
                          product: null
                        %}
                      {% else %}
                        <a class="card__title" href="{{ sublink.url }}"> {{ sublink.title }}</a>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
              {% else %}
                {% if link.type == 'product_link' or link.type == 'collection_link' %}
                  {% render 'card',
                    img: link.object.featured_image,
                    url: link.object.url,
                    title: link.object.title,
                    product: null
                  %}
                {% else %}
                  <a class="card__title" href="{{ link.url }}"> {{ link.title }}</a>
                {% endif %}
              {% endif %}
            {% endcomment %}
          </li>
        {%- endfor -%}
      </ul>
    </div>
    <div class="search-result-top-right">
      <slideshow-section class="wt-slider">
        <div data-swiper class="wt-slider__container">
          <div data-swiper-container class="swiper-wrapper">
            {% for product in settings.search_product_suggestion %}
              {% if section.settings.show_secondary_image and product.images[1] %}
                {% assign image_hover = product.images[1] %}
              {% else %}
                {% assign image_hover = false %}
              {% endif %}

              <div data-swiper-slide class="swiper-slide">
                {% render 'card',
                  card_product: product,
                  img: product.featured_media,
                  img_hover: image_hover,
                  title: product.title,
                  subtitle: product.vendor,
                  rating: section.settings.show_product_rating,
                  reviews: product.metafields.reviews,
                  options: false,
                  url: product.url,
                  uri: product.handle,
                  text_alignment: section.settings.text_alignment,
                  variants: product.variants,
                  product_options: product.options,
                  product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  enable_quick_add_button: section.settings.enable_quick_add_button,
                  quick_add_mode: section.settings.quick_add_mode,
                  enable_vendor_link: section.settings.enable_vendor_link
                %}
              </div>
            {% endfor %}
          </div>

          {% if settings.search_product_suggestion.count > 1 %}
            <div class="swiper-button-next wt-slider__nav-btn wt-slider__nav-next wt-slider__nav-next--search">
              {% render 'icons', id: 'arrow-right' %}
            </div>
            <div class="swiper-button-prev wt-slider__nav-btn wt-slider__nav-prev wt-slider__nav-prev--search">
              {% render 'icons', id: 'arrow-left' %}
            </div>
          {% endif %}
        </div>

        <script data-swiper-configuration type="text/json">
          {
            "slidesPerView": 1.3,
            "spaceBetween": 16,
            "autoHeight": false,
            "watchSlidesProgress": true,
            "breakpoints": {
              "600": {
                "slidesPerView": 2
              },
              "900": {
                "slidesPerView": 3
              }
            }
          }
        </script>
      </slideshow-section>
    </div>
  </div>
</div>
