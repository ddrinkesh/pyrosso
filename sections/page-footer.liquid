<style>
  [id="shopify-section-{{ section.id }}"]
  {
          --section-gap-top: {{ section.settings.margin-top }}px;
          --section-gap-bottom: {{ section.settings.margin-bottom }}px;
          --big-logo-width: {{ section.settings.big-logo-width }}%;
  }

  {%- for block in section.blocks -%}
    [data-block-id="{{ block.id }}"]
    {
      --size-image: {{ block.settings.image-width }}px;
      {% if block.type == 'image_with_text' %}
        --image-width-desktop: {{ block.settings.image_width_desktop }}px;
        --image-width-mobile: {{ block.settings.image_width_mobile }}px;
        --image-with-text-color: {{ block.settings.color }};
      {% endif %}
    }
  {%- endfor -%}

  .svg-anim-block {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }
  .svg-anim-inner {
    width: 100%;
    max-width: 608px;
    margin: 0;
  }
  #animated-svg path {
    fill: #969696;
    fill-opacity: 0;
    stroke: white;
    stroke-width: 0.816862;
  }
</style>

{% if section.settings['show-scroll-effect'] %}
  <script>
    (function () {
      const FOOTER_SCROLL_CLASS = 'footer-scroll-effect';
      const MIN_SECTION_RATIO = 1.5; // viewport multiplier (150%)
      const rootSection = document.querySelector('main#root');

      // check root section height condition
      const hasRequiredRootHeight = rootSection
        ? rootSection.offsetHeight >= window.innerHeight * MIN_SECTION_RATIO
        : false;

      function getAvailableViewportHeight() {
        const header = document.querySelector('[data-sticky-always="true"]');
        const headerHeight = header ? header.offsetHeight : 0;
        return window.innerHeight - headerHeight;
      }

      function updateFooterScrollClass() {
        const footer = document.querySelector('footer.wt-footer');
        const footerHeight = footer ? footer.offsetHeight : 0;

        const availableHeight = getAvailableViewportHeight();
        const footerFitsViewport = footerHeight < availableHeight;

        if (!footerFitsViewport) {
          document.body.classList.remove(FOOTER_SCROLL_CLASS);
          return;
        }

        const scrollBottomPos = window.innerHeight + window.scrollY;
        const footerShowPos = document.documentElement.scrollHeight - footerHeight;

        const atBottom = scrollBottomPos >= document.documentElement.scrollHeight;

        // if viewport bottom has reached the top of the footer AND root is tall enough, add the class
        if (scrollBottomPos >= footerShowPos && hasRequiredRootHeight) {
          document.body.classList.add(FOOTER_SCROLL_CLASS);
        } else {
          // otherwise remove the class
          document.body.classList.remove(FOOTER_SCROLL_CLASS);
        }

        // if scrolled all the way to the bottom of the page,
        // remove the class to improve mobile UX when footer collapsible sections open
        if (atBottom) {
          if (window.innerWidth < 1200) {
            document.body.classList.remove(FOOTER_SCROLL_CLASS);
          }
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        if (!hasRequiredRootHeight) {
          document.body.classList.remove(FOOTER_SCROLL_CLASS);
          return;
        }

        updateFooterScrollClass();
        window.addEventListener('scroll', updateFooterScrollClass, { passive: true });
        window.addEventListener('resize', updateFooterScrollClass, { passive: true });
      });
    })();
  </script>
{% endif %}

<footer class="wt-footer {% if section.settings.show-scroll-effect %}wt-footer--scroll-effect{% endif %}">
  <div class="wt-footer__top wt-footer__body">
    <div class="wt-footer__top__newsletter">
      <section class="wt-newsletter wt-footer__additional wt-signup" data-signup>
        <div class="wt-signup__head">
          {%- if section.settings.heading_newsletter != blank -%}
            <div class="wt-signup__heading">{{ section.settings.heading_newsletter }}</div>
          {%- endif -%}

          {%- if section.settings.enable_sms -%}
            <div class="wt-signup__tabs" role="tablist" aria-label="Sign up method">
              <button
                type="button"
                class="wt-signup__tab is-active"
                data-signup-tab="email"
                role="tab"
                aria-selected="true"
              >
                {{ section.settings.email_tab_label | default: 'Email' }}
              </button>
              <button
                type="button"
                class="wt-signup__tab"
                data-signup-tab="sms"
                role="tab"
                aria-selected="false"
              >
                {{ section.settings.sms_tab_label | default: 'SMS' }}
              </button>
            </div>
          {%- endif -%}
        </div>

        <div class="wt-signup__body">
          {% form 'customer', class: 'newsletter-form wt-newsletter__form wt-signup__form wt-footer__additional__form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">

            <div
              class="wt-signup__panel is-active"
              data-signup-panel="email"
            >
              <div class="wt-signup__field-wrap">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="wt-signup__field"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  placeholder="{{ section.settings.email_placeholder | default: 'Enter your email.' }}"
                  required
                >
                <button type="submit" class="wt-signup__submit" name="commit" aria-label="{{ 'newsletter.button_label' | t }}">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M2.5 8h11M9 3.5 13.5 8 9 12.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </div>

            {%- if section.settings.enable_sms -%}
              <div
                class="wt-signup__panel"
                data-signup-panel="sms"
              >
                <div class="wt-signup__field-wrap">
                  <input
                    type="tel"
                    name="contact[phone]"
                    class="wt-signup__field"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="tel"
                    placeholder="{{ section.settings.sms_placeholder | default: 'Enter your phone number.' }}"
                    disabled
                  >
                  <button type="submit" class="wt-signup__submit" name="commit" aria-label="{{ 'newsletter.button_label' | t }}">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M2.5 8h11M9 3.5 13.5 8 9 12.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>
            {%- endif -%}

            {%- if section.settings.disclaimer_text != blank -%}
              <div class="wt-signup__disclaimer rte">{{ section.settings.disclaimer_text }}</div>
            {%- endif -%}

            {%- if form.errors -%}
              <div class="form__message">
                <div class="form__error-field">
                  {% for error in form.errors %}
                    <p id="Newsletter-error--{{ section.id }}">
                      {% if error == 'form' %}
                        {{ form.errors.messages[error] }}
                      {% else %}
                        {{ form.errors.translated_fields[error] }} - {{ form.errors.messages[error] }}
                      {% endif %}
                    </p>
                  {% endfor %}
                </div>
              </div>
            {%- endif -%}

            {%- if form.posted_successfully? -%}
              <div class="form__message">
                <div class="form__success-field" tabindex="-1" autofocus>
                  <p>{{- 'newsletter.success' | t }}</p>
                </div>
              </div>
            {%- endif -%}
          {% endform %}
        </div>
      </section>
    </div>

    <div class="svg-anim-block" id="svgAnimBlock">
