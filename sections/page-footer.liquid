      </div>
    </div>
  </div>

  <div class="wt-footer__mobile-bar">
    <a href="{{ routes.root_url }}" class="wt-footer__mobile-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.footer_logo != blank -%}
        {{
          section.settings.footer_logo
          | image_url: width: 370
          | image_tag: loading: 'lazy', alt: shop.name, class: 'wt-footer__mobile-logo-img'
        }}
      {%- else -%}
        <span class="wt-footer__mobile-logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <div class="wt-footer__mobile-social">
      {% render 'social-links' %}
    </div>
  </div>

  <div class="wt-footer__body wt-footer__menus">
    {% for block in section.blocks %}
      <div class="wt-footer__block wt-footer__block--{{ block.type }}">
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
          {%- when 'custom_liquid' -%}
            {{ block.settings.custom_liquid }}
          {%- when 'menu' -%}
            {% if block.settings.heading_links != empty %}
              {% comment %}
                  <collapsible-section
                    class="wt-footer__links wt-collapse"
                    data-toggle-tabindex="button, [href], input, a"
                    data-mobile-only
                  >
                <div
                  class="wt-footer__title wt-collapse__trigger"
                  role="button"
                  tabindex="0"
                  data-open="false"
                  aria-expanded="false"
                  aria-controls="CollapsibleTab-{{ block.id }}"
                >
              {% endcomment %}
              <div class="wt-footer__title">{{ block.settings.heading_links }}</div>
              {% comment %}
                <div class="wt-footer__title__icon wt-icon" aria-hidden="true">
                  {% render 'icons', id: 'plus' %}
                </div>
              {% endcomment %}
              {% comment %}
                </div>
                <div class="wt-collapse__target wt-collapse__target--v2" id="CollapsibleTab-{{ block.id }}">
              {% endcomment %}
              <ul class="wt-footer__list">
                {%- for link in block.settings.links.links -%}
                  <li class="wt-footer__list__item">
                    <a href="{{ link.url }}" class="{% if link.active %} list-menu__item--active{% endif %}">
                      <span class="wt-footer__list__item__text--underline">{{ link.title }}</span>
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
              {% comment %}
                </div>
                </collapsible-section>
              {% endcomment %}
            {% else %}
              <div class="wt-footer__links wt-footer__links--no-heading">
                <ul class="wt-footer__list">
                  {%- for link in block.settings.links.links -%}
                    <li class="wt-footer__list__item">
                      <a href="{{ link.url }}" class="{% if link.active %} list-menu__item--active{% endif %}">
                        <span class="wt-footer__list__item__text--underline">{{ link.title }}</span>
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {% endif %}

          {%- when 'social_menu' -%}
            {% if block.settings.heading_links != empty %}
              {% comment %}
                <collapsible-section
                  class="wt-footer__links wt-collapse"
                  data-toggle-tabindex="button, [href], input, a"
                  data-mobile-only
                >
                  <div
                    class="wt-footer__title wt-collapse__trigger"
                    role="button"
                    tabindex="0"
                    data-open="false"
                    aria-expanded="false"
                    aria-controls="CollapsibleTab-{{ block.id }}"
                  >
              {% endcomment %}
              <div class="wt-footer__title">{{ block.settings.heading_links }}</div>
              {% comment %}
                <div class="wt-footer__title__icon wt-icon" aria-hidden="true">
                  {% render 'icons', id: 'plus' %}
                </div>
              {% endcomment %}
              {% comment %}
                </div>
                <div class="wt-collapse__target wt-collapse__target--v2" id="CollapsibleTab-{{ block.id }}">
              {% endcomment %}
              <ul class="wt-footer__list footer-social-links">
                {% if settings.social_facebook_link != empty %}
                  <li class="wt-footer__list__item">
                    <a
                      href="{{ settings.social_facebook_link }}"
                      class="social-link"
                      aria-label="Facebook - opens in new tab"
                      target="_blank"
                      rel="nofollow"
                    >
                      {% render 'icons', id: 'soc-fb' %}
                      <span class="wt-footer__list__item__text--underline">
                        {{- 'general.social.links.facebook' | t -}}
                      </span>
                    </a>
                  </li>
                {% endif %}
                {% if settings.social_tiktok_link != empty %}
                  <li class="wt-footer__list__item">
                    <a
                      href="{{ settings.social_tiktok_link }}"
                      class="social-link"
                      aria-label="TikTok - opens in new tab"
                      target="_blank"
                      rel="nofollow"
                    >
                      {% render 'icons', id: 'soc-tiktok' %}
                      <span class="wt-footer__list__item__text--underline">
                        {{ 'general.social.links.tiktok' | t }}
                      </span>
                    </a>
                  </li>
                {% endif %}
                {% if settings.social_youtube_link != empty %}
                  <li class="wt-footer__list__item">
                    <a
                      href="{{ settings.social_youtube_link }}"
                      class="social-link"
                      aria-label="Youtube- opens in new tab"
                      target="_blank"
                      rel="nofollow"
                    >
                      {% render 'icons', id: 'soc-youtube' %}
                      <span class="wt-footer__list__item__text--underline">
                        {{ 'general.social.links.youtube' | t }}
                      </span>
                    </a>
                  </li>
                {% endif %}
                {% if settings.social_instagram_link != empty %}
                  <li class="wt-footer__list__item">
                    <a
                      href="{{ settings.social_instagram_link }}"
                      class="social-link"
                      aria-label="Instagram - opens in new tab"
                      target="_blank"
                      rel="nofollow"
                    >
                      {% render 'icons', id: 'soc-inst' %}
                      <span class="wt-footer__list__item__text--underline">
                        {{ 'general.social.links.instagram' | t }}
                      </span>
                    </a>
                  </li>
                {% endif %}
                {% if settings.social_twitter_link != empty %}
                  <li class="wt-footer__list__item">
                    <a
                      href="{{ settings.social_twitter_link }}"
                      class="social-link"
                      aria-label="Twitter - opens in new tab"
                      target="_blank"
                      rel="nofollow"
                    >
                      {% render 'icons', id: 'soc-twitter' %}
                      <span class="wt-footer__list__item__text--underline">
                        {{ 'general.social.links.twitter' | t }}
                      </span>
                    </a>
                  </li>
                {% endif %}
                {% if settings.social_pinterest_link != empty %}
                  <li class="wt-footer__list__item">
                    <a
                      href="{{ settings.social_pinterest_link }}"
                      class="social-link"
                      aria-label="Pinterest - opens in new tab"
                      target="_blank"
                      rel="nofollow"
                    >
                      {% render 'icons', id: 'soc-pint' %}
                      <span class="wt-footer__list__item__text--underline">
                        {{ 'general.social.links.pinterest' | t }}
                      </span>
                    </a>
                  </li>
                {% endif %}
                {% if settings.social_tumblr_link != empty %}
                  <li class="wt-footer__list__item">
                    <a
                      href="{{ settings.social_tumblr_link }}"
                      class="social-link"
                      aria-label="Tumblr - opens in new tab"
                      target="_blank"
                      rel="nofollow"
                    >
                      {% render 'icons', id: 'soc-tumblr' %}
                      <span class="wt-footer__list__item__text--underline">
                        {{ 'general.social.links.tumblr' | t }}
                      </span>
                    </a>
                  </li>
                {% endif %}
                {% if settings.social_snapchat_link != empty %}
                  <li class="wt-footer__list__item">
                    <a
                      href="{{ settings.social_snapchat_link }}"
                      class="social-link"
                      aria-label="Snapchat - opens in new tab"
                      target="_blank"
                      rel="nofollow"
                    >
                      {% render 'icons', id: 'soc-snapchat' %}
                      <span class="wt-footer__list__item__text--underline">
                        {{ 'general.social.links.snapchat' | t }}
                      </span>
                    </a>
                  </li>
                {% endif %}
                {% if settings.social_vimeo_link != empty %}
                  <li class="wt-footer__list__item">
                    <a
                      href="{{ settings.social_vimeo_link }}"
                      class="social-link"
                      aria-label="Vimeo"
                      target="_blank"
                      rel="nofollow"
                    >
                      {% render 'icons', id: 'soc-vimeo' %}
                      <span class="wt-footer__list__item__text--underline">
                        {{ 'general.social.links.vimeo' | t }}
                      </span>
                    </a>
                  </li>
                {% endif %}
              </ul>
              {% comment %}
                </div>
                </collapsible-section>
              {% endcomment %}
            {% else %}
              <div class="wt-footer__links wt-footer__links--no-heading">
                <ul class="wt-footer__list">
                  {%- for link in block.settings.links.links -%}
                    <li class="wt-footer__list__item">
                      <a href="{{ link.url }}" class="{% if link.active %} list-menu__item--active{% endif %}">
                        <span class="wt-footer__list__item__text--underline">{{ link.title }}</span>
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {% endif %}

          {%- when 'text' -%}
            <section class="wt-footer__msg{% if block.settings.heading_text == blank %} wt-footer__msg--no-heading{% endif %}">
              {%- if block.settings.heading_text != blank -%}
                <div class="wt-footer__title">{{ block.settings.heading_text }}</div>
              {%- endif -%}
              <div class="wt-footer__text rte">{{ block.settings.text }}</div>
            </section>

          {%- when 'image' -%}
            <section class="wt-footer__msg" data-block-id="{{ block.id }}">
              {% if block.settings.desktop_image != blank %}
                {% assign alt_text = block.settings.desktop_image.alt | escape | default: '' %}
                {{
                  block.settings.desktop_image
                  | image_url: width: 750
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 750px) 750px, 320px',
                    widths: '750, 1500, 3000',
                    alt: alt_text,
                    class: 'wt-footer__image'
                }}
              {% else %}
                {{ 'collection-apparel-2' | placeholder_svg_tag: 'wt-footer__image' }}
              {% endif %}
            </section>

          {%- when 'image_with_text' -%}
            <section class="wt-footer__msg wt-footer__image-with-text" data-block-id="{{ block.id }}">
              {% if block.settings.image != blank %}
                {%- assign footer_img_alt = block.settings.image.alt | default: '' | escape -%}
                {{
                  block.settings.image
                  | image_url: width: 750
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 750px) 750px, 320px',
                    widths: '750, 1500, 3000',
                    alt: footer_img_alt,
                    class: 'wt-footer__image-with-text__image'
                }}
              {% endif %}
              <div class="wt-footer__text rte">{{ block.settings.text }}</div>
            </section>
        {%- endcase -%}
      </div>
    {%- endfor -%}
  </div>

  <div class="wt-footer__aside_wrapper">
    <div class="wt-footer__aside">
      {% if section.settings.show_country_selector
        or section.settings.show_language_selector
        or section.settings['show-social-media-icons']
        or section.settings['show-payments-icons']
      %}
        <div class="wt-footer__aside__wrapper">
          {% if section.settings.show_country_selector
            or section.settings.show_language_selector
            or section.settings['show-social-media-icons']
          %}
            <div class="wt-footer__aside-block__wrapper">
              {% if section.settings.show_country_selector or section.settings.show_language_selector %}
                <div
                  class="wt-footer__localization__triggers"
                >
                  {% if section.settings.show_country_selector -%}
                    {%- render 'localization-btn-local',
                      show_country_code: section.settings.show_country_selector_label,
                      show_country_flag: section.settings.show_country_selector_flag
                    -%}
                  {%- endif %}
                  {% if section.settings.show_language_selector %}{% render 'localization-btn-lang' %}{% endif %}
                </div>
              {% endif %}

              {% if section.settings['show-social-media-icons'] %}
                <div class="wt-footer__aside-block wt-footer__aside-block--social">
                  {% render 'social-links' %}
                </div>
              {% endif %}
            </div>
          {% endif %}

          {% if section.settings['show-payments-icons'] %}
            <div class="wt-footer__aside-block wt-footer__aside-block--payment{% if section.settings.payment_icons_monochrome %} wt-footer__aside-block--payment-monochrome{% endif %}">
              <ul class="wt-footer__aside-list" role="list">
                {%- for type in shop.enabled_payment_types -%}
                  <li class="wt-footer__aside-list__item">
                    {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {% endif %}
          {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
            <div class="footer__follow-on-shop">
              {{ shop | login_button: action: 'follow' }}
            </div>
          {%- endif -%}
        </div>
      {% endif %}

      {% if section.settings['show-copyright'] %}
        <p class="wt-footer__aside__copy">
          {{ section.settings.text }}
        </p>
      {% endif %}
    </div>
  </div>

  {% if section.settings['big-logo'] != null %}
    <div class="wt-footer__big-logo">
      {% assign big_logo = section.settings['big-logo'] | get_image %}
      {% assign alt_text = big_logo.alt | escape | default: '' %}
      {{
        section.settings['big-logo']
        | image_url: width: 3840
        | image_tag:
          loading: 'lazy',
          widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          alt: alt_text,
          class: 'wt-footer__big-logo-img',
          sizes: '100vw'
      }}
    </div>
  {% endif %}
</footer>

<script>
  (function () {
    document.querySelectorAll('[data-signup]').forEach(function (root) {
      var tabs = root.querySelectorAll('[data-signup-tab]');
      var panels = root.querySelectorAll('[data-signup-panel]');
      if (!tabs.length) return;

      function activate(name) {
        tabs.forEach(function (tab) {
          var on = tab.getAttribute('data-signup-tab') === name;
          tab.classList.toggle('is-active', on);
          tab.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        panels.forEach(function (panel) {
          var on = panel.getAttribute('data-signup-panel') === name;
          panel.classList.toggle('is-active', on);
          // only the visible panel's field submits
          panel.querySelectorAll('input').forEach(function (input) {
            input.disabled = !on;
          });
        });
      }

      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          activate(tab.getAttribute('data-signup-tab'));
        });
      });
    });
  })();
</script>

<script>
  (function () {
    var paths   = Array.from(document.querySelectorAll('#animated-svg path'));
    var block   = document.getElementById('svgAnimBlock');
    if (!paths.length || !block) return;
    var lengths = paths.map(function(p) { return p.getTotalLength(); });
    var animating = false;
    var startTime = null;
    var rafId     = null;
    var DURATION  = 2200;

    function resetPaths() {
      paths.forEach(function(p, i) {
        p.style.strokeDasharray  = lengths[i];
        p.style.strokeDashoffset = lengths[i];
        p.style.fillOpacity      = 0;
      });
    }

    resetPaths();

    function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

    function easeInOut(t) {
      return t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t + 2, 3) / 2;
    }

    function applyProgress(progress) {
      var n = paths.length;
      paths.forEach(function(p, i) {
        var seg  = clamp((progress - i / n) / (1 / n), 0, 1);
        var draw = clamp(seg * 2, 0, 1);
        var fill = clamp((seg - 0.5) * 2, 0, 1);
        p.style.strokeDashoffset = lengths[i] * (1 - draw);
        p.style.fillOpacity      = fill * 0.718;
      });
    }

    function animate(timestamp) {
      if (!startTime) startTime = timestamp;
      var raw      = clamp((timestamp - startTime) / DURATION, 0, 1);
      var progress = easeInOut(raw);
      applyProgress(progress);
      if (raw < 1) {
        rafId = requestAnimationFrame(animate);
      } else {
        animating = false;
        rafId     = null;
      }
    }

    function startAnimation() {
      if (rafId) cancelAnimationFrame(rafId);
      resetPaths();
      animating = true;
      startTime = null;
      rafId = requestAnimationFrame(animate);
    }

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            startAnimation();
          } else {
            if (rafId) cancelAnimationFrame(rafId);
            animating = false;
            rafId     = null;
            resetPaths();
          }
        });
      }, { threshold: 0.3 });

      observer.observe(block);
    } else {
      applyProgress(1);
    }
  })();
</script>

