            "open_by_default": false
          }
        },
        "collapsible_tab_mEVcgJ": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "How much product should I use?",
            "content": "<p>A small amount goes a long way. Start with a fingertip-sized amount, warm it between your hands, and build up only if needed. Using too much product can reduce texture and movement.</p>",
            "page": "",
            "open_by_default": false
          }
        },
        "collapsible_tab_bcpFj3": {
          "type": "collapsible_tab",
          "settings": {
