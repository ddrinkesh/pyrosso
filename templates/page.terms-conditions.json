        "text_MbQLAy": {
          "type": "text",
          "settings": {
            "text": "<p>All products offered by Pyrosso are intended for personal use only and not for resale unless explicitly authorized by us.</p><p>We strive to display accurate product descriptions, pricing, and availability. However, we do not guarantee that all information on the Site is error-free. We reserve the right to correct errors, update information, or cancel orders at any time, including after an order has been submitted.</p><p>Product availability is not guaranteed, and we may limit quantities per order or customer.</p>"
          }
