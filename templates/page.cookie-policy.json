        },
        "text_XBYcqj": {
          "type": "text",
          "settings": {
            "text": "<p>You can manage or disable cookies through your browser settings at any time. Please note that disabling certain cookies may impact the functionality and performance of the Site.</p><p>Where required by law, we provide a cookie consent banner or management tool that allows you to accept, reject, or customize cookie preferences.</p>"
